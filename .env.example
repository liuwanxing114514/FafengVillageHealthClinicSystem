# PostgreSQL
POSTGRES_DB=clinic
POSTGRES_USER=clinic
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# 数据目录（宿主机，对应 docs/共用/DEPLOYMENT.md）
CLINIC_DATA_DIR=./clinic-data

# 服务端口
BACKEND_PORT=8080
FRONTEND_PORT=80

# Spring
SPRING_PROFILES_ACTIVE=prod

# AI（v0.9 预留，默认关闭）
CLINIC_AI_ENABLED=false
CLINIC_AI_PROVIDER=noop
