# =============================================================================
# 发凤村卫生室诊所系统 — 环境配置样本
#
# 首次部署（群晖 NAS）：cp .env.example .env → 修改 POSTGRES_PASSWORD、CLINIC_DATA_DIR
# 版本更新：diff .env.example .env，仅追加缺失项，勿整文件覆盖
#
# IDEA 本地开发（profile=dev）：
# - Spring Boot 不会自动读取 .env；Run Configuration 需 EnvFile 或手动环境变量
# - 数据库见 backend/src/main/resources/application-dev.yml
# =============================================================================

# --- AI 分项开关速查（可独立关闭）---
# Chat/Agent：CLINIC_AI_ENABLED=false + CLINIC_AI_PROVIDER=noop
# Whisper：CLINIC_WHISPER_URL 留空（默认不部署，用手机输入法语音）
# OCR：CLINIC_OCR_URL 留空 + 不启 --profile ocr
# RAG：CLINIC_EMBEDDING_ENABLED=false

# --- 数据库（PostgreSQL，docker compose）---
POSTGRES_DB=clinic
POSTGRES_USER=clinic
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# --- 数据目录（程序与数据分离）---
# 群晖 DS920+ 建议：
CLINIC_DATA_DIR=/volume1/clinic-data
BACKEND_PORT=8080
FRONTEND_PORT=8088

# =============================================================================
# AI 总开关（v0.9+）
# =============================================================================
CLINIC_AI_ENABLED=false
CLINIC_AI_PROVIDER=noop

# --- Chat / Agent / 病历整理（v1.3+）---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

LOCAL_AI_BASE_URL=http://localhost:11434

# --- 病历向量化 v2.2（硅基流动 BAAI/bge-m3，1024 维）---
CLINIC_EMBEDDING_ENABLED=false
CLINIC_EMBEDDING_PROVIDER=openai
CLINIC_EMBEDDING_API_KEY=
CLINIC_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
CLINIC_EMBEDDING_MODEL=BAAI/bge-m3
CLINIC_EMBEDDING_DIMENSIONS=1024
CLINIC_EMBEDDING_LOCAL_BASE_URL=http://localhost:1234/v1
CLINIC_EMBEDDING_SYNC_CRON=
CLINIC_EMBEDDING_BATCH_SIZE=16

# --- Whisper（v1.1，默认不部署；留空即可）---
# 生产推荐：手机浏览器病历页 → 输入法语音键录入
# 若启 whisper 容器：CLINIC_WHISPER_URL=http://whisper-service:9000
CLINIC_WHISPER_URL=
WHISPER_PORT=9000
CLINIC_VOICE_UPLOAD_DIR=uploads/audio
CLINIC_VOICE_SAVE_AUDIO=true

# --- OCR 入库（v1.4，可选）---
# 启 ocr 容器后：CLINIC_OCR_URL=http://ocr-service:8000
CLINIC_OCR_URL=
OCR_PORT=8000
CLINIC_OCR_UPLOAD_DIR=uploads/images

# --- AI 全关最低配置（core 三容器即可）---
# CLINIC_AI_ENABLED=false
# CLINIC_AI_PROVIDER=noop
# CLINIC_WHISPER_URL=
# CLINIC_OCR_URL=
# CLINIC_EMBEDDING_ENABLED=false

# --- 硅基流动统一 Key 示例（Chat + Embedding）---
# CLINIC_AI_ENABLED=true
# CLINIC_AI_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-xxxxxxxx
# DEEPSEEK_BASE_URL=https://api.siliconflow.cn/v1
# DEEPSEEK_MODEL=deepseek-ai/DeepSeek-V3
# CLINIC_EMBEDDING_ENABLED=true
# CLINIC_EMBEDDING_API_KEY=sk-xxxxxxxx
# CLINIC_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# CLINIC_EMBEDDING_MODEL=BAAI/bge-m3
# CLINIC_EMBEDDING_DIMENSIONS=1024
