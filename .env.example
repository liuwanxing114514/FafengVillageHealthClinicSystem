# Docker Compose 可选配置（复制为 .env 后修改）
# 不创建 .env 也可启动，下列为 docker-compose.yml 中的默认值
# Spring 数据源配置见 backend/src/main/resources/application-*.yml

POSTGRES_DB=clinic
POSTGRES_USER=clinic
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

CLINIC_DATA_DIR=./clinic-data
BACKEND_PORT=8080
FRONTEND_PORT=80

# AI（v0.9 预留，默认关闭）
CLINIC_AI_ENABLED=false
CLINIC_AI_PROVIDER=noop
DEEPSEEK_API_KEY=
LOCAL_AI_BASE_URL=http://localhost:11434
