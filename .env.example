# Docker Compose 可选配置（复制为 .env 后修改）
# 不创建 .env 也可启动，下列为 docker-compose.yml 中的默认值
# Spring 数据源配置见 backend/src/main/resources/application-*.yml

POSTGRES_DB=clinic
POSTGRES_USER=clinic
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

CLINIC_DATA_DIR=./clinic-data
BACKEND_PORT=8080
FRONTEND_PORT=80

# AI（v0.9 预留，默认关闭）
CLINIC_AI_ENABLED=false
CLINIC_AI_PROVIDER=noop
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LOCAL_AI_BASE_URL=http://localhost:11434

# v1.1 Whisper 语音转写（可选，启用 whisper profile 后填写）
# docker compose --profile whisper up -d
# CLINIC_WHISPER_URL=http://whisper-service:9000
CLINIC_WHISPER_URL=
WHISPER_PORT=9000
CLINIC_VOICE_UPLOAD_DIR=uploads/audio
CLINIC_VOICE_SAVE_AUDIO=true

# v1.4 OCR 入库（可选，启用 ocr profile 后填写）
# docker compose --profile ocr up -d
# CLINIC_OCR_URL=http://ocr-service:8000
CLINIC_OCR_URL=
OCR_PORT=8000
CLINIC_OCR_UPLOAD_DIR=uploads/images
