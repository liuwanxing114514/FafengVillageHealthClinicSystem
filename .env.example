# =============================================================================
# 发凤村卫生室诊所系统 — 环境配置样本
# 复制本文件为 .env 后按诊所实际情况修改
# 升级时：对比本文件新增项，追加到现有 .env，勿整文件覆盖（会丢失已设密码）
#
# IDEA 本地开发（profile=dev）：
# - Spring Boot 不会自动读取 .env；Run Configuration 需 EnvFile 插件或手动填环境变量
# - 数据库见 backend/src/main/resources/application-dev.yml（postgres/admin），非本文件 POSTGRES_*
# - 密钥勿提交 Git；泄露后请在硅基流动控制台轮换
# =============================================================================

# --- 数据库（PostgreSQL，主要供 docker compose）---
POSTGRES_DB=clinic
POSTGRES_USER=clinic
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# --- 数据目录（程序与数据分离）---
# Windows 诊所机建议：CLINIC_DATA_DIR=D:/clinic-data
CLINIC_DATA_DIR=./clinic-data
BACKEND_PORT=8080
FRONTEND_PORT=80

# =============================================================================
# AI 总开关（v0.9+）
# 关闭时：手动入库/病历/处方照常；语音/OCR/AI 整理/向量化同步不可用
# =============================================================================
CLINIC_AI_ENABLED=false
# 提供商：noop（默认）| deepseek | local
CLINIC_AI_PROVIDER=noop

# --- Chat / Agent / 病历整理（v1.3+）---
# 推荐：硅基流动统一 Key（Chat + Embedding 同平台，见下方 CLINIC_EMBEDDING_*）
# DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_BASE_URL=https://api.siliconflow.cn/v1
# DEEPSEEK_MODEL=deepseek-ai/DeepSeek-V3
# 或 DeepSeek 官网：
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

LOCAL_AI_BASE_URL=http://localhost:11434

# --- 病历向量化 v2.2（脱敏后出站 → PostgreSQL pgvector）---
# 生产/测试推荐：硅基流动 BAAI/bge-m3（1024 维）
CLINIC_EMBEDDING_ENABLED=false
CLINIC_EMBEDDING_PROVIDER=openai
CLINIC_EMBEDDING_API_KEY=
CLINIC_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
CLINIC_EMBEDDING_MODEL=BAAI/bge-m3
CLINIC_EMBEDDING_DIMENSIONS=1024
CLINIC_EMBEDDING_LOCAL_BASE_URL=http://localhost:1234/v1
CLINIC_EMBEDDING_SYNC_CRON=
CLINIC_EMBEDDING_BATCH_SIZE=16

# --- Whisper 语音转写（v1.1，可选）---
CLINIC_WHISPER_URL=
WHISPER_PORT=9000
CLINIC_VOICE_UPLOAD_DIR=uploads/audio
CLINIC_VOICE_SAVE_AUDIO=true

# --- OCR 入库（v1.4，可选）---
CLINIC_OCR_URL=
OCR_PORT=8000
CLINIC_OCR_UPLOAD_DIR=uploads/images

# --- 硅基流动统一 Key 示例（生产 + 本地 IDEA 测试）---
# CLINIC_AI_ENABLED=true
# CLINIC_AI_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-xxxxxxxx
# DEEPSEEK_BASE_URL=https://api.siliconflow.cn/v1
# DEEPSEEK_MODEL=deepseek-ai/DeepSeek-V3
# CLINIC_EMBEDDING_ENABLED=true
# CLINIC_EMBEDDING_API_KEY=sk-xxxxxxxx
# CLINIC_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# CLINIC_EMBEDDING_MODEL=BAAI/bge-m3
# CLINIC_EMBEDDING_DIMENSIONS=1024
