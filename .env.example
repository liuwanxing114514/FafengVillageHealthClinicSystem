# =============================================================================
# 发凤村卫生室诊所系统 — 环境配置样本
# 复制本文件为 .env 后按诊所实际情况修改
# 升级时：对比本文件新增项，追加到现有 .env，勿整文件覆盖（会丢失已设密码）
# =============================================================================

# --- 数据库（PostgreSQL）---
POSTGRES_DB=clinic
POSTGRES_USER=clinic
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# --- 数据目录（程序与数据分离）---
# Windows 诊所机建议：CLINIC_DATA_DIR=D:/clinic-data
CLINIC_DATA_DIR=./clinic-data
BACKEND_PORT=8080
FRONTEND_PORT=80

# --- AI 总开关（v0.9+，默认关闭，不影响基础业务）---
# 关闭时：手动入库/病历/处方照常；语音/OCR/AI 整理不可用
CLINIC_AI_ENABLED=false
# 提供商：noop（默认）| deepseek | local
CLINIC_AI_PROVIDER=noop

# --- DeepSeek（v1.3 病历整理 + v1.4 OCR 表格整理，需外网 API）---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 本地大模型（远期占位）
LOCAL_AI_BASE_URL=http://localhost:11434

# --- Whisper 语音转写（v1.1，可选）---
# 启用：docker compose --profile whisper up -d
# 容器内地址：CLINIC_WHISPER_URL=http://whisper-service:9000
CLINIC_WHISPER_URL=
WHISPER_PORT=9000
CLINIC_VOICE_UPLOAD_DIR=uploads/audio
CLINIC_VOICE_SAVE_AUDIO=true

# --- OCR 入库（v1.4，可选）---
# 前置：CLINIC_AI_ENABLED=true + CLINIC_AI_PROVIDER=deepseek + DEEPSEEK_API_KEY
# 启用：docker compose --profile ocr up -d
# 容器内地址：CLINIC_OCR_URL=http://ocr-service:8000
CLINIC_OCR_URL=
OCR_PORT=8000
CLINIC_OCR_UPLOAD_DIR=uploads/images

# --- 诊所启用 OCR 入库示例（按需取消注释）---
# CLINIC_AI_ENABLED=true
# CLINIC_AI_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-xxxxxxxx
# CLINIC_OCR_URL=http://ocr-service:8000

# --- 诊所同时启用语音 + OCR 示例 ---
# docker compose --profile whisper --profile ocr up -d --build
# CLINIC_WHISPER_URL=http://whisper-service:9000
# CLINIC_OCR_URL=http://ocr-service:8000
